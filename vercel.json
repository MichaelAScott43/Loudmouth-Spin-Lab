{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "dist/**",     "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)",     "dest": "/dist/$1" }
  ],
  "env": {
    "FB_APP_ID":     "@fb-app-id",
    "FB_APP_SECRET": "@fb-app-secret"
  }
}

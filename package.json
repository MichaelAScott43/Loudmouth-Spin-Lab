{
  "name": "loudmouth-spin-lab",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
    "build:web": "expo export --platform web",
    "test": "jest --watchAll"
  },
  "jest": {
    "preset": "jest-expo"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.0",
    "expo": "~52.0.0",
    "expo-font": "~13.0.1",
    "expo-linear-gradient": "~14.0.1",
    "expo-splash-screen": "~0.29.13",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.5",
    "react-native-web": "~0.19.13"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/react": "~18.3.12",
    "jest": "^29.7.0",
    "jest-expo": "~52.0.0"
  },
  "private": true
  "type": "module",
  "description": "Loudmouth Spin Lab – Facebook Instant Games slot machine",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:fb": "vite build && cd dist && zip -r ../loudmouth-spin-lab.zip . && cd ..",
    "upload:fb": "node scripts/upload-fb.js",
    "deploy:fb": "npm run build:fb && npm run upload:fb",
    "preview": "vite preview",
    "start": "vite preview --host 0.0.0.0",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "phaser": "^3.87.0"
  },
  "devDependencies": {
    "archiver": "^7.0.0",
    "form-data": "^4.0.5",
    "jest": "^29.7.0",
    "vite": "^5.4.0"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {}
  }
}
